scripts/skill_optimize.sh
scripts/__pycache__/

# Local project metadata (Hermes-internal, not part of upstream project)
.hermes/

# Failed variants saved by evolve_skill.py (manual inspection only)
*_FAILED.md

# IDE
.idea/
.vscode/
*.swp
*.swo
